{
	"name": "vite-react-18",
	"homepage": "https://kishan-singh-code.github.io/my-app",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"build:pages": "tsc -b && vite build --base=/my-app/ && cp dist/index.html dist/404.html",
		"predeploy": "yarn build:pages",
		"deploy": "gh-pages -d dist",
		"lint": "prettier . --check",
		"format": "prettier . --write",
		"preview": "vite preview"
	},
	"dependencies": {
		"@ant-design/icons": "^6.2.5",
		"antd": "^6.4.3",
		"axios": "^1.17.0",
		"crypto-js": "^4.2.0",
		"dayjs": "^1.11.21",
		"mathjs": "^15.2.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-is": "^19.2.7",
		"react-router-dom": "6",
		"recharts": "^3.8.1"
	},
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/react": "^18.3.1",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.4.1",
		"gh-pages": "^6.3.0",
		"prettier": "^3.5.3",
		"typescript": "~5.8.3",
		"vite": "^6.3.5"
	}
}
